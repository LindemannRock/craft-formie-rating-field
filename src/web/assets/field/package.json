{
  "name": "@lindemannrock/formie-rating-field",
  "version": "1.0.0",
  "private": true,
  "description": "Build tools for Formie Rating Field plugin",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "mkdir -p dist/css && cleancss -o dist/css/rating.css src/css/rating.css",
    "build:js": "mkdir -p dist/js && terser src/js/rating.js -o dist/js/rating.js -c -m"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "terser": "^5.46.1"
  },
  "author": {
    "name": "Bilal Harry Lindemann",
    "email": "hello@lindemannrock.com",
    "url": "https://lindemannrock.com"
  },
  "company": {
    "name": "LindemannRock",
    "url": "https://lindemannrock.com"
  },
  "license": "Proprietary"
}
