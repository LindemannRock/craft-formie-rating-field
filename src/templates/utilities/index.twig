{% extends 'lindemannrock-base/_layouts/cp-utilities' %}

{% set plugin = craft.app.plugins.getPlugin('formie-rating-field') %}
{% set settings = plugin.settings %}
{% set cacheCount = plugin.statistics.getCacheFileCount() %}
{% set storageMethod = settings.cacheStorageMethod %}

{# Permission checks #}
{% set canViewStatistics = currentUser.can('formieRatingField:viewStatistics') %}
{% set canManageCache = currentUser.can('formieRatingField:manageCache') %}
{% set canManageSettings = currentUser.can('formieRatingField:manageSettings') %}

{% set hasNavigation = canViewStatistics or canManageSettings %}
{% set hasCacheManagement = canManageCache %}
{% set hasAnyQuickAction = hasNavigation or hasCacheManagement %}

{% set utilitiesConfig = {
    plugin: {
        handle: 'formie-rating-field',
        name: ratingHelper.fullName,
    },
    page: {
        title: 'Overview'|t('formie-rating-field'),
        description: 'Manage statistics cache and monitor performance.'|t('formie-rating-field'),
    },
} %}

{% block overview %}
    {# Cache Status Card - only show if user can manage cache #}
    {% if canManageCache %}
        {% if storageMethod == 'redis' %}
            {% include 'lindemannrock-base/_components/unified-card' with {
                title: 'Cache Status (Redis)'|t('formie-rating-field'),
                color: lrPaletteColor('emerald').color,
                value: 'Active'|t('formie-rating-field'),
            } only %}
        {% else %}
            {% include 'lindemannrock-base/_components/unified-card' with {
                title: 'Cache Status (File)'|t('formie-rating-field'),
                color: lrPaletteColor('emerald').color,
                value: cacheCount,
                description: 'Cached statistics'|t('formie-rating-field'),
            } only %}
        {% endif %}
    {% endif %}
{% endblock %}

{% block quickActions %}
    {% if hasAnyQuickAction %}
        {# Navigation Section #}
        {% if hasNavigation %}
            {% set navButtons = [] %}
            {% if canViewStatistics %}
                {% set navButtons = navButtons|merge([{type: 'link', label: 'View Statistics'|t('formie-rating-field'), url: url('formie-rating-field/statistics')}]) %}
            {% endif %}
            {% if canManageSettings %}
                {% set navButtons = navButtons|merge([{type: 'link', label: 'Manage settings'|t('formie-rating-field'), url: url('formie-rating-field/settings')}]) %}
            {% endif %}

            {% include 'lindemannrock-base/_layouts/cp-utilities/_action-section' with {
                title: 'Navigation'|t('formie-rating-field'),
                description: 'Access main plugin sections'|t('formie-rating-field'),
                buttons: navButtons,
            } only %}
        {% endif %}

        {# Cache Management Section #}
        {% if hasCacheManagement %}
            {% include 'lindemannrock-base/_layouts/cp-utilities/_action-section' with {
                title: 'Cache Management'|t('formie-rating-field'),
                description: 'Generate or clear statistics cache. Generation may take several minutes for large datasets.'|t('formie-rating-field'),
                showSeparator: hasNavigation,
                buttons: [
                    {id: 'generate-cache', label: 'Generate Cache Now'|t('formie-rating-field')},
                    {id: 'clear-all-cache', label: 'Clear All Cache'|t('formie-rating-field'), class: 'btn secondary'},
                ],
            } only %}
        {% endif %}
    {% endif %}
{% endblock %}

{% block scripts %}
{% if canManageCache %}
{% js %}
{% include 'lindemannrock-base/_layouts/cp-utilities/_ajax-button' with {
    id: 'generate-cache',
    action: actionUrl('formie-rating-field/cache/generate-all'),
    confirm: 'This will generate cache for all forms with rating fields. This may take several minutes. Continue?'|t('formie-rating-field'),
    successMessage: 'Cache generation started'|t('formie-rating-field'),
    errorMessage: 'Failed to start cache generation'|t('formie-rating-field'),
    reloadDelay: 2000,
} only %}

{% include 'lindemannrock-base/_layouts/cp-utilities/_ajax-button' with {
    id: 'clear-all-cache',
    action: actionUrl('formie-rating-field/cache/clear-all'),
    confirm: 'Clear all statistics cache?'|t('formie-rating-field'),
    successMessage: 'Cache cleared successfully'|t('formie-rating-field'),
    errorMessage: 'Failed to clear cache'|t('formie-rating-field'),
    reloadDelay: 1000,
} only %}
{% endjs %}
{% endif %}
{% endblock %}
