{#
 # Statistics Index - Using cp-table layout
 #
 # Lists all Formie forms that contain rating fields, with sort, search,
 # pagination, and optional site filter.
 #}

{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# ============================================================================
   SITE FILTER OPTIONS
   ============================================================================ #}

{% set siteFilterOptions = [{value: 'all', label: 'All Sites'|t('formie-rating-field'), status: 'all'}] %}
{% for site in editableSites %}
    {% set siteFilterOptions = siteFilterOptions|merge([{
        value: site.id,
        label: site.name,
    }]) %}
{% endfor %}

{# ============================================================================
   TABLE CONFIGURATION
   ============================================================================ #}

{% set tableConfig = {
    plugin: {
        handle: 'formie-rating-field',
        name: ratingHelper.fullName,
    },
    page: {
        title: 'Statistics'|t('formie-rating-field'),
        subnav: 'statistics',
        crumbs: [
            {label: ratingHelper.fullName, url: url('formie-rating-field')},
            {label: 'Statistics'|t('formie-rating-field'), url: url('formie-rating-field/statistics')},
        ],
    },
    filters: editableSites|length > 1 ? [
        {
            type: 'dropdown',
            param: 'siteId',
            current: siteId,
            label: 'All Sites'|t('formie-rating-field'),
            options: siteFilterOptions,
        },
    ] : [],
    search: {
        placeholder: 'Search forms...'|t('formie-rating-field'),
        value: search,
    },
    sort: {
        field: sort,
        direction: dir,
    },
    table: {
        columns: [
            {key: 'title', label: 'Form Title'|t('formie-rating-field'), sortable: true},
            {key: 'handle', label: 'Handle'|t('formie-rating-field'), sortable: true, hideable: true},
            {key: 'ratingFieldCount', label: 'Rating Fields'|t('formie-rating-field'), sortable: true},
            {key: 'totalSubmissions', label: 'Total Submissions'|t('formie-rating-field'), sortable: true},
        ],
        items: forms,
        emptyMessage: 'No forms with rating fields found.'|t('formie-rating-field'),
    },
    pagination: {
        page: page,
        limit: limit,
        totalCount: totalItems,
        itemLabel: {singular: 'form'|t('formie-rating-field'), plural: 'forms'|t('formie-rating-field')},
    },
    checkboxes: false,
    rowActions: false,
} %}

{# ============================================================================
   CUSTOM ROW RENDERING
   ============================================================================ #}

{% block tableRow %}
    {# Form Title with link to per-form statistics #}
    <td>
        <a class="label-link" href="{{ url('formie-rating-field/statistics/form/' ~ item.form.id ~ (siteId != 'all' ? '?siteId=' ~ siteId : '')) }}">
            <span>{{ item.form.title }}</span>
        </a>
    </td>

    {# Handle #}
    <td><code>{{ item.form.handle }}</code></td>

    {# Rating field count #}
    <td>{{ item.ratingFieldCount|number }}</td>

    {# Total submissions #}
    <td>{{ item.totalSubmissions|number_format }}</td>
{% endblock %}
