{% set title = "Interface Settings"|t('formie-rating-field') %}
{% set fullPageForm = not (readOnly ?? false) %}
{% set selectedSettingsItem = 'interface' %}
{% if readOnly ?? false %}
    {% set contentNotice = readOnlyNotice() %}
{% endif %}

{% extends "formie-rating-field/_layouts/settings" %}

{% set crumbs = [
    {
        label: ratingHelper.fullName|t('formie-rating-field'),
        url: url('formie-rating-field'),
    },
    {
        label: 'Settings'|t('formie-rating-field'),
        url: url('formie-rating-field/settings'),
    },
    {
        label: 'Interface'|t('formie-rating-field'),
        url: url('formie-rating-field/settings/interface'),
    },
] %}

{% import "_includes/forms" as forms %}

{% block content %}
{% if not (readOnly ?? false) %}
    {{ actionInput('formie-rating-field/settings/save') }}
    {{ redirectInput('formie-rating-field/settings/interface') }}
    {{ hiddenInput('section', 'interface') }}
{% endif %}

<fieldset class="first">
	<h2>{{ 'Interface Settings'|t('formie-rating-field') }}</h2>

	{% include 'lindemannrock-base/_partials/field-items-per-page' with {
        settings: settings,
        pluginHandle: 'formie-rating-field',
    } only %}

	{{ forms.textField({
        label: 'Max Export Rows'|t('formie-rating-field'),
        instructions: 'Hard cap on the number of rows included in the "Raw Responses" export. Protects against PHP out-of-memory errors on high-volume forms (each row hydrates a full submission element). Set to 0 for unlimited (use with care).'|t('formie-rating-field'),
        id: 'maxExportRows',
        name: 'settings[maxExportRows]',
        type: 'number',
        value: settings.maxExportRows ?? 50000,
        min: 0,
        max: 1000000,
        required: true,
        disabled: settings.isOverriddenByConfig('maxExportRows'),
        warning: settings.isOverriddenByConfig('maxExportRows') ?
            "This is being overridden by the <code>maxExportRows</code> setting in <code>config/formie-rating-field.php</code>."|t('formie-rating-field')|raw : null,
        errors: settings.getErrors('maxExportRows')
    }) }}
</fieldset>

<hr>

{% include 'lindemannrock-base/_partials/cascade-base-overrides' with {
    settings: settings,
    pluginHandle: 'formie-rating-field',
    sections: {
        dateFormat: {},
        dateRange: {},
        exports: {},
    },
} only %}

{% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}
