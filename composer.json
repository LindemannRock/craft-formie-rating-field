{
	"name": "lindemannrock/craft-formie-rating-field",
	"description": "Rating field for Formie - Provides star rating, emoji rating, and numeric rating field types for Craft CMS Formie plugin",
	"type": "craft-plugin",
	"version": "3.18.0",
	"keywords": [
		"craft",
		"cms",
		"craftcms",
		"craft-plugin",
		"formie",
		"rating field",
		"star rating"
	],
	"license": "proprietary",
	"authors": [
		{
			"name": "Bilal Hary Lindemann",
			"email": "bh@lindemannrock.com",
			"homepage": "https://lindemannrock.com",
			"role": "Developer"
		}
	],
	"support": {
		"email": "support@lindemannrock.com",
		"issues": "https://github.com/LindemannRock/craft-formie-rating-field/issues",
		"source": "https://github.com/LindemannRock/craft-formie-rating-field",
		"docs": "https://github.com/LindemannRock/craft-formie-rating-field/blob/main/README.md",
		"rss": "https://github.com/LindemannRock/craft-formie-rating-field/commits/main.atom"
	},
	"require": {
		"php": "^8.2",
		"craftcms/cms": "^5.0.0",
		"verbb/formie": "^3.0.0",
		"lindemannrock/craft-plugin-base": "^5.0"
	},
	"require-dev": {
		"craftcms/ecs": "dev-main",
		"craftcms/phpstan": "dev-main",
		"phpunit/phpunit": "^11.0"
	},
	"suggest": {
		"craftcms/feed-me": "For importing Rating field data via Feed Me"
	},
	"autoload": {
		"psr-4": {
			"lindemannrock\\formieratingfield\\": "src/",
			"lindemannrock\\formieratingfield\\tests\\": "tests/"
		}
	},
	"scripts": {
		"phpstan": "phpstan --ansi --memory-limit=1G",
		"check-cs": "ecs check --ansi",
		"fix-cs": "ecs check --fix --ansi",
		"test": "phpunit --colors=always",
		"install-hooks": "git config core.hooksPath .githooks 2>/dev/null || true",
		"post-install-cmd": "@install-hooks",
		"post-update-cmd": "@install-hooks"
	},
	"config": {
		"allow-plugins": {
			"craftcms/plugin-installer": true,
			"yiisoft/yii2-composer": true,
			"php-http/discovery": true
		}
	},
	"extra": {
		"name": "Formie Rating Field",
		"handle": "formie-rating-field",
		"developer": "LindemannRock",
		"developerUrl": "https://lindemannrock.com",
		"documentationUrl": "https://github.com/LindemannRock/craft-formie-rating-field/blob/main/README.md",
		"changelogUrl": "https://github.com/LindemannRock/craft-formie-rating-field/blob/main/CHANGELOG.md",
		"class": "lindemannrock\\formieratingfield\\FormieRatingField"
	}
}
